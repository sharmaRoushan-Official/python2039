    "# 8. check Whether Given year is Leap Year or not\n",
    "\n",
    "year=int(input(\"Enter a Year \"))\n",
    "\n",
    "if year%400==0:\n",
    "    print(f\"{year} is Leap year\")\n",
    "elif year%4==0:\n",
    "    print(f\"{year} is Leap year\")\n",
    "elif year%100==0:\n",
    "    print(f\"{year} is Not Leap year\")\n",
    "else:\n",
    "    print(\f"{year} is Not a Leap year\")"
   ]
